# Supabase (aus `npx supabase status` oder Supabase-Cloud-Dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dev-only: Dummy-User-Mode (leeren oder auf 'false' setzen für echten Auth-Flow)
# Wenn 'true', wird Auth-Guard in /admin übersprungen und ein Dummy-Admin eingeloggt.
NEXT_PUBLIC_DEV_DUMMY_AUTH=true
